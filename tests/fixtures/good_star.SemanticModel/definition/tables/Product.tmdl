/// One row per product, fully flattened from category to item.
table Product

	column ProductKey
		dataType: int64
		summarizeBy: none
		isHidden

	/// The product name as shown to the business.
	column ProductName
		dataType: string
		summarizeBy: none

	/// The product category, flattened into the product dimension.
	column Category
		dataType: string
		summarizeBy: none
